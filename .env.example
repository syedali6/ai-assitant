# Environment variables for AI Research Assistant
# Copy this file to .env and fill in your keys

# ─── LLM Provider ─────────────────────────────────────────────────────
# Choose "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI API Key (required if LLM_PROVIDER=openai)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Models ───────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-pro
OPENAI_MODEL=gpt-4o

# ─── Embeddings ───────────────────────────────────────────────────────
# Choose "huggingface" (free, local) or "openai"
EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_MODEL=all-MiniLM-L6-v2

# ─── Chunking ─────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─── Retrieval ────────────────────────────────────────────────────────
RETRIEVER_K=5

# ─── LLM Generation ───────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ─── Memory ───────────────────────────────────────────────────────────
MEMORY_WINDOW=5
